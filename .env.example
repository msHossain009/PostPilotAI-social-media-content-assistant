# ─────────────────────────────────────────────────────────────────
# .env.example — PostPilot AI environment variable template
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your real values in .env
#   3. Never commit .env — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────

# ── AI API Settings ───────────────────────────────────────────────

# Your API key from the provider (required)
AI_API_KEY=sk-vgiWcDpjux7nLnhaBOAXBQSm4HC2LFceSWSRyFACwPDBHOlN

# Base URL of the AI provider's API
# OpenAI:           https://api.openai.com/v1
# Groq:             https://api.groq.com/openai/v1
# Google Gemini:    https://generativelanguage.googleapis.com/v1beta/openai
# IBM watsonx:      your-watsonx-openai-compat-url
AI_BASE_URL=https://api.chatanywhere.tech/v1

# The model to use
# OpenAI:           gpt-4o-mini  (fast, cheap, great quality)
# Groq:             llama3-8b-8192
# Gemini:           gemini-1.5-flash

# ── Server Settings ───────────────────────────────────────────────

# The port the Express server listens on (default: 3000)
PORT=3000

# Optional: set to "production" when deploying
# NODE_ENV=production
